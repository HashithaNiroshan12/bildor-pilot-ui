{
  "name": "bildor-pilot-ui-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/ui",
    "build": "npm run build --workspace=packages/ui",
    "typecheck": "npm run typecheck --workspace=packages/ui",
    "lint": "npm run lint --workspace=packages/ui",
    "storybook": "npm run storybook --workspace=packages/ui",
    "build-storybook": "npm run build-storybook --workspace=packages/ui"
  }
}
